{
    "name": "abhi-port-root",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "start": "node server/index.js",
        "build": "npm install && npm run build --prefix client",
        "server": "nodemon server/index.js",
        "client": "npm run dev --prefix client",
        "dev": "concurrently \"npm run server\" \"npm run client\""
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "mongoose": "^7.6.3",
        "nodemailer": "^8.0.1",
        "openai": "^4.14.2"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "nodemon": "^3.0.1"
    }
}